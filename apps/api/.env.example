CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ORIGIN_REGEX=
DATABASE_URL=sqlite:///./autolv.db
# 운영(PostgreSQL) 예시:
# DATABASE_URL=postgresql+psycopg://autolv:your_password@db-host:5432/autolv
JWT_SECRET_KEY=change-me-access-key
JWT_REFRESH_SECRET_KEY=change-me-refresh-key
ACCESS_TOKEN_EXP_MINUTES=60
REFRESH_TOKEN_EXP_DAYS=14
VWORLD_API_BASE_URL=https://api.vworld.kr
VWORLD_API_DOMAIN=localhost
VWORLD_TIMEOUT_SECONDS=15
VWORLD_RETRY_COUNT=2
VWORLD_RETRY_BACKOFF_SECONDS=0.35
VWORLD_USER_AGENT=autoLV/1.0 (+https://auto-lv.vercel.app)
VWORLD_REFERER=https://auto-lv.vercel.app
# Railway->VWorld 네트워크 문제 시 Web(Vercel) 프록시를 경유할 수 있음.
VWORLD_PROXY_URL=
VWORLD_PROXY_TOKEN=
VWORLD_API_KEY=your-vworld-api-key
ROAD_NAME_FILE_PATH=
LD_CODE_FILE_PATH=
BULK_STORAGE_DIR=./storage/bulk
BULK_MAX_ROWS=10000
BULK_LOOKUP_WORKERS=6
BULK_PROGRESS_UPDATE_MIN_SECONDS=1.0
PROFILE_IMAGE_DIR=./storage/profile_images
REDIS_URL=
REDIS_PNU_TTL_SECONDS=86400
MAP_PRICE_CACHE_TTL_SECONDS=86400
MAP_NEARBY_RADIUS_M=200
MAP_ZONE_OVERLAP_THRESHOLD=0.9
MAP_ZONE_MAX_VERTICES=100
MAP_ZONE_MAX_AREA_SQM=5000000
MAP_ZONE_QUERY_TIMEOUT_MS=10000
MAP_ZONE_VWORLD_PAGE_SIZE=1000
MAP_ZONE_VWORLD_MAX_PAGES=20
EMAIL_VERIFICATION_EXP_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_DEBUG_RETURN_CODE=true
MAIL_DELIVERY_MODE=console
MAIL_FROM=no-reply@autolv.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
